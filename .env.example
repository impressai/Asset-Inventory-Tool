# ─── App ─────────────────────────────────────────────────────
APP_ENV=development

# ─── Security (REQUIRED — generate with: openssl rand -hex 32) ─
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ─── Database ─────────────────────────────────────────────────
POSTGRES_DB=asset_inventory
POSTGRES_USER=asset_user
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql://asset_user:devpassword@db:5432/asset_inventory

# ─── pgAdmin (dev only) ───────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ─── AWS (optional — required for S3 document storage) ───────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_DOCUMENTS=asset-inventory-documents

# ─── Email (optional) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── Frontend ─────────────────────────────────────────────────
REACT_APP_API_BASE_URL=http://localhost:8000/api/v1
